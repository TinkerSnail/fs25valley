<?xml version="1.0" encoding="utf-8" standalone="no"?>
<modDesc descVersion="105">
    <author>Your Name</author>
    <version>0.1.0.70</version>

    <title>
        <en>Valley Life</en>
        <de>Valley Life</de>
    </title>
    <description>
        <en>Authored villagers, relationships, and scripted heart events for Farming Simulator 25.
Primary target map: Riverbend Springs. Singleplayer only.</en>
    </description>

    <multiplayer supported="false"/>

    <iconFilename>icon.dds</iconFilename>

    <extraSourceFiles>
        <!-- main.lua uses source() to load all other files in the correct order -->
        <sourceFile filename="main.lua"/>
    </extraSourceFiles>

    <actions>
        <action name="VL_INTERACT" axisType="HALF"/>
        <action name="VL_UP" axisType="HALF"/>
        <action name="VL_DOWN" axisType="HALF"/>
    </actions>

    <inputBinding>
        <actionBinding action="VL_INTERACT">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_r"/>
        </actionBinding>
        <actionBinding action="VL_UP">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_up"/>
        </actionBinding>
        <actionBinding action="VL_DOWN">
            <binding device="KB_MOUSE_DEFAULT" input="KEY_down"/>
        </actionBinding>
    </inputBinding>

    <l10n filenamePrefix="translations/lang" defaultLanguage="en"/>
</modDesc>

# Normalize line endings across Mac + Windows so shared scripts never break.
# Shell scripts MUST be LF — CRLF breaks bash (incl. Git Bash/MINGW on Windows).
* text=auto

*.sh   text eol=lf
*.lua  text eol=lf
*.xml  text eol=lf
*.md   text eol=lf
*.ps1  text eol=crlf

# Binary assets — never touch.
*.dds  binary
*.png  binary
*.zip  binary
*.i3d  binary
